# OpenAI (DALL-E 3, TTS, Whisper, Agents SDK)
OPENAI_API_KEY=

# xAI Grok Imagine (animation)
XAI_API_KEY=

# Social publishing (pick a provider — Ayrshare, Buffer, or direct platform APIs)
AYRSHARE_API_KEY=

# Modal (set via `modal token set`, not env)

# Supabase Postgres (use the pooler connection string for the runtime app).
MARKETER_DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Clerk JWT verification for the FastAPI backend.
MARKETER_CLERK_JWKS_URL=https://<your-clerk-frontend>.clerk.accounts.dev/.well-known/jwks.json
MARKETER_CLERK_ISSUER=https://<your-clerk-frontend>.clerk.accounts.dev

# Pipeline defaults (per-niche values override these — kept for ops scripts).
MARKETER_ASPECT=9:16

# Maximum number of scene-asset tasks (image + animation) that run in parallel.
# Decrease to reduce burst spend and provider rate-limit pressure.
MARKETER_SCENE_FANOUT_LIMIT=4

# Concurrency caps for the nightly batch scheduler.
# Global: total Modal containers for run_pipeline across the whole deployment.
MARKETER_PIPELINE_GLOBAL_CONCURRENCY=20
# Per-user: max simultaneous jobs for one user (advisory lock via Postgres).
MARKETER_PIPELINE_PER_USER_CONCURRENCY=3
# Per-niche: max simultaneous jobs for one niche; 1 serializes to prevent
# character-sheet write races.
MARKETER_PIPELINE_PER_NICHE_CONCURRENCY=1

# CORS allow-list for the FastAPI backend. Comma-separated origins (no
# trailing slash). Leave empty in local dev to fall back to "*" with
# credentials disabled.
MARKETER_WEB_ORIGIN=https://your-app.vercel.app

# Sentry error reporting. Leave DSN empty to disable Sentry entirely.
# MARKETER_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
MARKETER_SENTRY_DSN=
MARKETER_SENTRY_ENVIRONMENT=production
MARKETER_SENTRY_TRACES_SAMPLE_RATE=0.0

# Ayrshare webhook HMAC secret. Must match the secret configured in your
# Ayrshare dashboard under Settings → Webhooks. Leave empty to disable
# webhook ingestion (the endpoint will return 503).
MARKETER_AYRSHARE_WEBHOOK_SECRET=

# Optional Redis URL for distributed rate-limit storage (slowapi).
# When unset, rate limits use in-process memory (safe for single-instance).
# MARKETER_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0

# OpenTelemetry tracing. Leave MARKETER_OTEL_EXPORTER_OTLP_ENDPOINT empty
# to disable OTEL entirely (no spans, no exporter, no overhead).
#
# Honeycomb:
#   MARKETER_OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io/
#   MARKETER_OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=<your-api-key>
#
# Axiom:
#   MARKETER_OTEL_EXPORTER_OTLP_ENDPOINT=https://api.axiom.co/
#   MARKETER_OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>,x-axiom-dataset=marketer
#
# Datadog:
#   MARKETER_OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.datadoghq.com/
#   MARKETER_OTEL_EXPORTER_OTLP_HEADERS=DD-API-KEY=<key>
#
# Grafana Tempo (self-hosted):
#   MARKETER_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/
#   MARKETER_OTEL_EXPORTER_OTLP_HEADERS=
#
MARKETER_OTEL_EXPORTER_OTLP_ENDPOINT=
MARKETER_OTEL_SERVICE_NAME=marketer
MARKETER_OTEL_EXPORTER_OTLP_HEADERS=
MARKETER_OTEL_TRACES_SAMPLE_RATE=1.0

# --- Hosted product (Route A) ------------------------------------------
# Prepaid-credits billing. Leave disabled for self-hosted deployments —
# the pipeline then runs on your keys with only your spend caps.
MARKETER_BILLING_ENABLED=false
# Debit multiplier over raw provider cost (1.5 = cost + 50%).
MARKETER_BILLING_MARGIN=1.5
MARKETER_STRIPE_SECRET_KEY=
# From the Stripe dashboard webhook endpoint (checkout.session.completed
# -> https://<api>/api/v1/billing/webhook).
MARKETER_STRIPE_WEBHOOK_SECRET=
# Public origin for checkout redirects and email links.
MARKETER_APP_URL=https://your-app.vercel.app

# Transactional email (Resend). Empty = notifications silently skipped.
MARKETER_RESEND_API_KEY=
MARKETER_EMAIL_FROM="marketer <notifications@yourdomain.com>"

# --- Web (Vercel project env, not backend) -------------------------------
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...   (required at build time)
# CLERK_SECRET_KEY=sk_live_...                    (required by middleware)
# NEXT_PUBLIC_API_BASE_URL=https://<your-api>     (FastAPI origin the proxy forwards to)

# --- Article pipeline (written content / SEO) -------------------------------
# Exa API key for SERP research. Optional: unset degrades research to model
# knowledge instead of failing runs. https://exa.ai
MARKETER_EXA_API_KEY=
# Long-form writer model (defaults to the agent model).
MARKETER_ARTICLE_WRITER_MODEL=gpt-5.4-mini
# Generate an editorial hero image per article (gpt-image-1).
MARKETER_ARTICLE_HERO_IMAGE=true
