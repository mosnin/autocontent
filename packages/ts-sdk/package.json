{
  "name": "@marketer/sdk",
  "version": "0.1.0",
  "description": "Typed TypeScript client for the marketer.sh public API.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "generate": "openapi-typescript ../../docs/api/openapi.json -o src/types.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18"
  }
}
